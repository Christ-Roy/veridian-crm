# Veridian CRM — prod .env example
#
# Posé côté Dokploy compose ENV (pas dans le repo Git).
# Génération des secrets départ propre :
#   POSTGRES_PASSWORD=$(openssl rand -base64 32 | tr -d '/+=' | cut -c1-32)
#   TWENTY_APP_SECRET=$(openssl rand -base64 64 | tr -d '/+=' | cut -c1-64)
#
# SMTP : récupérer depuis ~/credentials/.all-creds.env côté machine locale.

# --- Postgres (DB CRM) ---
POSTGRES_PASSWORD=

# --- Twenty server secret (signe les JWT, hash workspaces) ---
TWENTY_APP_SECRET=

# --- SMTP Lark Veridian (envoi des invites workspace, magic links Twenty) ---
SMTP_HOST=smtp.larksuite.com
SMTP_PORT=465
SMTP_USER=robert.brunon@veridian.site
SMTP_PASS=
SMTP_ADMIN_EMAIL=robert.brunon@veridian.site
SMTP_SENDER_NAME=Veridian CRM
